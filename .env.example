# Copy this file to `.env` and fill in real values. `.env` is git-ignored and
# must never be committed. The container is started with: --env-file .env

# --- OpenAI ---------------------------------------------------------------
# A single OpenAI key powers BOTH the embedding model and the chat model.
# Create one at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-key-here

# Embedding model used at ingestion AND query time. These MUST stay identical
# or retrieval breaks. Change only if you re-ingest the whole document.
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536

# Chat / generation model.
CHAT_MODEL=gpt-4o-mini
CHAT_TEMPERATURE=0.0

# --- Qdrant Cloud ---------------------------------------------------------
# Cloud-hosted vector store. Create a free cluster at https://cloud.qdrant.io
# QDRANT_URL is the cluster endpoint, e.g.
#   https://xxxxxxxx-xxxx-xxxx.region.aws.cloud.qdrant.io:6333
QDRANT_URL=https://your-cluster-url.cloud.qdrant.io:6333
QDRANT_API_KEY=your-qdrant-api-key-here
QDRANT_COLLECTION=iphone_user_guide

# --- Chunking (used by the ingestion script only) -------------------------
CHUNK_SIZE=1000
CHUNK_OVERLAP=150

# --- Retrieval ------------------------------------------------------------
RETRIEVAL_K=5

# --- App ------------------------------------------------------------------
# Port the Chainlit UI listens on. Map it with: docker run -p 8000:8000 ...
APP_PORT=8000
